# --- PostgreSQL (Prisma) ---
# El NOMBRE de la base va en la URL, entre el puerto y "?":
#   postgresql://USER:PASSWORD@HOST:5432/NOMBRE_AQUI?schema=public
# Ejemplo: .../gemini?schema=public  →  base lógica "gemini", schema "public".
# Para usar otra base: créala en Postgres (CREATE DATABASE otra_db;) y cambia solo ese segmento + ejecuta migrate.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gemini?schema=public"

PORT=3000

# development | production — en prod: logger sin debug/verbose; Swagger off salvo SWAGGER_ENABLED=1
# NODE_ENV=development

# Swagger UI en /api/docs. Default: ON en dev, OFF en production. Forzar: SWAGGER_ENABLED=1|0
# SWAGGER_ENABLED=1

# Fase 1: 0 = imágenes off (503). Dev local para probar upload: 1
FEATURE_PRODUCT_IMAGES=0

# API (excepto GET / y GET /api/v1/ops/metrics): enviar header X-Store-Id = UUID de tienda con BusinessSettings configurado

# TTL de filas `IdempotencyRecord` (horas). Default 168 (7 días). Máx. ~720 h en código.
# IDEMPOTENCY_TTL_HOURS=168

# Onboarding desde POS: PUT /api/v1/stores/:storeId y PUT .../business-settings (sin login). Solo redes de confianza.
# STORE_ONBOARDING_ENABLED=1

# Reset dev — borra datos de Postgres (migrate reset + seed):
#   npm run db:reset:dev
# (cross-env ya pone ALLOW_DEV_DB_RESET=1). Equivalente directo: npm run db:reset

# M5 — observabilidad (opcional)
# OPS_SCHEDULER_ENABLED=1
# OPS_SCHEDULER_INTERVAL_MS=120000
# WARN periódicos del scheduler (sync failed, inventario): solo si NODE_ENV != production.
# En prod usar GET /api/v1/ops/metrics bajo demanda.
# Proteger GET /api/v1/ops/metrics (API key y/o allowlist). Si ambos están vacíos, /ops queda abierto.
# En desarrollo el aviso va a nivel verbose; en NODE_ENV=production es WARN en consola.
# OPS_API_KEY=cambia-en-produccion
# OPS_IP_ALLOWLIST=127.0.0.1,::1
# Tras reverse proxy, para que OPS_IP_ALLOWLIST vea el cliente real:
# TRUST_PROXY=1

# Dashboard operativo — PATCH /api/v1/pos-devices/:deviceId/dashboard-config
# En producción definir PIN; si vacío (y sin OPS_API_KEY), el PATCH queda abierto en dev.
# DASHBOARD_ADMIN_PIN=cambia-en-produccion

# --- Producción (EC2) — plantilla mínima ---
# NODE_ENV=production
# DATABASE_URL=postgresql://USER:PASS@rds-endpoint:5432/quickmarket?schema=public&sslmode=require
# OPS_API_KEY=generar-secreto-largo
# DASHBOARD_ADMIN_PIN=pin-operadores
# STORE_ONBOARDING_ENABLED=0
# FEATURE_PRODUCT_IMAGES=0
# TRUST_PROXY=1
# OPS_SCHEDULER_INTERVAL_MS=300000

# --- Plan B: Neon + Render (ver docs/NEON_RENDER_PHASE1_RUNBOOK.md) ---
# DATABASE_URL=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# NODE_ENV=production
# FEATURE_PRODUCT_IMAGES=0
# STORE_ONBOARDING_ENABLED=0
# OPS_SCHEDULER_ENABLED=0
# TRUST_PROXY=1
# SWAGGER_ENABLED=0
# PORT lo asigna Render — no definir en el dashboard
