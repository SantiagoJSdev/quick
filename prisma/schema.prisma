generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum ProductType {
  GOODS
  SERVICE
  CONSUMABLE
}

/// Cómo se determina el precio de lista respecto al costo y al margen de tienda.
enum ProductPricingMode {
  USE_STORE_DEFAULT
  USE_PRODUCT_OVERRIDE
  MANUAL_PRICE
}

enum StockMovementType {
  IN_PURCHASE
  IN_RETURN
  IN_ADJUST
  IN_TRANSFER
  OUT_SALE
  OUT_LOSS
  OUT_ADJUST
  OUT_TRANSFER
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

// --- Multi-moneda (Venezuela / ERP simplificado) ---
// Reglas: docs/domain/MULTI_CURRENCY_ARCHITECTURE.md
// Product.cost = costo medio en moneda funcional (semantica documentada).

model Currency {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  decimals  Int      @default(2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratesAsBase  ExchangeRate[] @relation("FxBaseCurrency")
  ratesAsQuote ExchangeRate[] @relation("FxQuoteCurrency")

  businessSettingsFunctional     BusinessSettings[] @relation("SettingsFunctionalCurrency")
  businessSettingsDefaultSaleDoc BusinessSettings[] @relation("SettingsDefaultSaleDocCurrency")
}

model ExchangeRate {
  id              String    @id @default(uuid())
  storeId         String?
  store           Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  baseCurrencyId  String
  baseCurrency    Currency  @relation("FxBaseCurrency", fields: [baseCurrencyId], references: [id])
  quoteCurrencyId String
  quoteCurrency   Currency  @relation("FxQuoteCurrency", fields: [quoteCurrencyId], references: [id])
  // 1 base = rateQuotePerBase quote
  rateQuotePerBase Decimal   @db.Decimal(30, 10)
  effectiveDate   DateTime  @db.Date
  source          String    @default("MANUAL")
  notes           String?
  createdAt       DateTime  @default(now())
  createdById     String?

  @@index([storeId, baseCurrencyId, quoteCurrencyId, effectiveDate])
}

model BusinessSettings {
  id                       String    @id @default(uuid())
  storeId                  String    @unique
  store                    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  functionalCurrencyId     String
  functionalCurrency       Currency  @relation("SettingsFunctionalCurrency", fields: [functionalCurrencyId], references: [id])
  defaultSaleDocCurrencyId String?
  defaultSaleDocCurrency   Currency? @relation("SettingsDefaultSaleDocCurrency", fields: [defaultSaleDocCurrencyId], references: [id])
  /// Margen comercial por defecto de la tienda (%), ej. 15.00 = 15%. Null = no configurado (UI puede usar lógica local hasta M7 completo).
  defaultMarginPercent     Decimal?  @db.Decimal(10, 4)

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("cashier")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
}

/// Contador global para SKUs autogenerados (`SKU-000001`). Una fila `id = global`.
model ProductSkuCounter {
  id         String @id @default("global")
  nextNumber Int    @default(0)
}

model Product {
  id             String     @id @default(uuid())
  sku            String     @unique
  barcode        String?    @unique
  name           String
  description    String?
  image          String?
  type           ProductType @default(GOODS)
  categoryId     String?
  category       Category?  @relation(fields: [categoryId], references: [id])

  price          Decimal    @default(0) @db.Decimal(65, 30)
  cost           Decimal    @default(0) @db.Decimal(65, 30)
  currency       String     @default("VES")

  taxId          String?
  tax            Tax?       @relation(fields: [taxId], references: [id])

  unit           String     @default("unidad")
  supplierId     String?
  supplier       Supplier?  @relation(fields: [supplierId], references: [id])

  pricingMode            ProductPricingMode @default(USE_STORE_DEFAULT)
  /// % de margen sobre costo cuando `pricingMode` = USE_PRODUCT_OVERRIDE; ignorado en otros modos salvo futuras reglas de sugerencia.
  marginPercentOverride  Decimal?           @db.Decimal(10, 4)

  inventoryItems InventoryItem[]
  movements      StockMovement[]
  saleLines      SaleLine[]
  saleReturnLines SaleReturnLine[]
  purchaseLines  PurchaseLine[]

  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([name])
  @@index([categoryId])
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tax {
  id        String    @id @default(uuid())
  name      String
  rate      Decimal   @db.Decimal(65, 30)
  code      String?
  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id             String   @id @default(uuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])

  quantity       Decimal  @default(0) @db.Decimal(65, 30)
  reserved       Decimal  @default(0) @db.Decimal(65, 30)
  minStock       Decimal  @default(0) @db.Decimal(65, 30)
  maxStock       Decimal? @db.Decimal(65, 30)
  locationInStore String?

  averageUnitCostFunctional Decimal @default(0) @db.Decimal(65, 30)
  totalCostFunctional       Decimal @default(0) @db.Decimal(65, 30)

  lastAdjustedAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productId, storeId])
}

model StockMovement {
  id            String           @id @default(uuid())
  opId          String?          @unique
  productId     String
  product       Product          @relation(fields: [productId], references: [id])
  storeId       String
  store         Store            @relation(fields: [storeId], references: [id])
  type          StockMovementType
  quantity      Decimal          @db.Decimal(65, 30)

  costAtMoment  Decimal?         @db.Decimal(65, 30)
  priceAtMoment Decimal?         @db.Decimal(65, 30)

  unitCostFunctional  Decimal? @db.Decimal(65, 30)
  totalCostFunctional Decimal? @db.Decimal(65, 30)

  referenceId   String?
  reason        String?
  createdAt     DateTime         @default(now())

  @@index([storeId, productId])
  @@index([createdAt])
}

model Supplier {
  id        String    @id @default(uuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  /// Identificador fiscal (RIF/CUIT/NIT); columna legada `rif` en Postgres.
  taxId     String?   @map("rif")
  email     String?
  phone     String?
  address   String?
  notes     String?
  active    Boolean   @default(true)

  products  Product[]
  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, active])
  @@index([storeId, name])
}

model Purchase {
  id           String         @id @default(uuid())
  supplierId   String
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  storeId      String
  store        Store          @relation(fields: [storeId], references: [id])

  status       String
  total        Decimal        @db.Decimal(65, 30)
  dateOrdered  DateTime       @default(now())
  dateReceived DateTime?

  documentCurrencyCode   String?
  functionalCurrencyCode String?
  fxBaseCurrencyCode     String?
  fxQuoteCurrencyCode    String?
  fxRateQuotePerBase     Decimal?   @db.Decimal(30, 10)
  exchangeRateDate       DateTime?  @db.Date
  fxSource               String?
  totalDocument          Decimal?   @db.Decimal(65, 30)
  totalFunctional        Decimal?   @db.Decimal(65, 30)

  /// Número de factura, nota de entrega u otra referencia del documento del proveedor.
  supplierInvoiceReference String?

  lines        PurchaseLine[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PurchaseLine {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  quantity   Decimal  @db.Decimal(65, 30)
  unitCost   Decimal  @db.Decimal(65, 30)
  totalCost  Decimal  @db.Decimal(65, 30)

  unitCostDocument     Decimal? @db.Decimal(65, 30)
  unitCostFunctional   Decimal? @db.Decimal(65, 30)
  lineTotalDocument    Decimal? @db.Decimal(65, 30)
  lineTotalFunctional  Decimal? @db.Decimal(65, 30)
}

model Store {
  id             String          @id @default(uuid())
  name           String
  type           String
  timezone       String?
  metadata       Json?

  inventory      InventoryItem[]
  stockMovements StockMovement[]
  purchases      Purchase[]
  posDevices     POSDevice[]
  sales          Sale[]
  saleReturns    SaleReturn[]
  businessSettings BusinessSettings?
  exchangeRates    ExchangeRate[]
  storeSyncState   StoreSyncState?
  syncOperations   SyncOperation[]
  suppliers        Supplier[]
  idempotencyRecords IdempotencyRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Respuestas cacheadas para cabecera `Idempotency-Key` (p. ej. `POST /products-with-stock`).
model IdempotencyRecord {
  id           String   @id @default(uuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  scope        String
  key          String
  requestHash  String   @db.VarChar(64)
  responseJson Json
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([storeId, scope, key])
  @@index([expiresAt])
}

/// Monotonic `serverVersion` per store for `POST /sync/push` acks (`acked[].serverVersion`).
/// `GET /sync/pull` uses `ServerChangeLog.serverVersion` instead (stream global de cambios del servidor).
model StoreSyncState {
  storeId       String   @id
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  serverVersion Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model POSDevice {
  id         String   @id @default(uuid())
  deviceId   String   @unique
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])
  lastSeen   DateTime?
  appVersion String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sales      Sale[]
  syncOps    SyncOperation[]
}

model Sale {
  id        String    @id @default(uuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  deviceId  String?
  posDevice POSDevice? @relation(fields: [deviceId], references: [deviceId])
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])

  total     Decimal   @db.Decimal(65, 30)
  status    String
  createdAt DateTime  @default(now())

  documentCurrencyCode   String?
  functionalCurrencyCode String?
  fxBaseCurrencyCode     String?
  fxQuoteCurrencyCode    String?
  fxRateQuotePerBase     Decimal?   @db.Decimal(30, 10)
  exchangeRateDate       DateTime?  @db.Date
  fxSource               String?
  totalDocument          Decimal?   @db.Decimal(65, 30)
  totalFunctional        Decimal?   @db.Decimal(65, 30)

  saleLines   SaleLine[]
  payments    SalePayment[]
  saleReturns SaleReturn[] @relation("SaleReturnFromSale")
}

model SalePayment {
  id                   String   @id @default(uuid())
  saleId               String
  sale                 Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method               String
  amount               Decimal  @db.Decimal(65, 30)
  currencyCode         String
  amountDocumentCurrency Decimal @db.Decimal(65, 30)
  fxBaseCurrencyCode   String?
  fxQuoteCurrencyCode  String?
  fxRateQuotePerBase   Decimal? @db.Decimal(30, 10)
  exchangeRateDate     DateTime? @db.Date
  fxSource             String?
  createdAt            DateTime @default(now())

  @@index([saleId])
}

model SaleReturn {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  originalSaleId String
  originalSale   Sale     @relation("SaleReturnFromSale", fields: [originalSaleId], references: [id])

  status    String   @default("CONFIRMED")
  total     Decimal  @db.Decimal(65, 30)
  createdAt DateTime @default(now())

  documentCurrencyCode   String?
  functionalCurrencyCode String?
  fxBaseCurrencyCode     String?
  fxQuoteCurrencyCode    String?
  fxRateQuotePerBase     Decimal?   @db.Decimal(30, 10)
  exchangeRateDate       DateTime?  @db.Date
  fxSource               String?
  totalDocument          Decimal?   @db.Decimal(65, 30)
  totalFunctional        Decimal?   @db.Decimal(65, 30)
  fxPolicy               String?    @db.VarChar(40)

  lines SaleReturnLine[]

  @@index([storeId])
  @@index([originalSaleId])
}

model SaleReturnLine {
  id           String     @id @default(uuid())
  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleLineId   String
  saleLine     SaleLine   @relation(fields: [saleLineId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(65, 30)

  unitPriceDocument    Decimal? @db.Decimal(65, 30)
  unitPriceFunctional  Decimal? @db.Decimal(65, 30)
  lineTotalDocument    Decimal? @db.Decimal(65, 30)
  lineTotalFunctional  Decimal? @db.Decimal(65, 30)

  @@index([saleLineId])
}

model SaleLine {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Decimal  @db.Decimal(65, 30)
  price     Decimal  @db.Decimal(65, 30)
  discount  Decimal? @db.Decimal(65, 30)
  total     Decimal? @db.Decimal(65, 30)

  unitPriceDocument    Decimal? @db.Decimal(65, 30)
  unitPriceFunctional  Decimal? @db.Decimal(65, 30)
  lineTotalDocument    Decimal? @db.Decimal(65, 30)
  lineTotalFunctional  Decimal? @db.Decimal(65, 30)
  discountDocument     Decimal? @db.Decimal(65, 30)
  discountFunctional   Decimal? @db.Decimal(65, 30)

  saleReturnLines SaleReturnLine[]
}

model SyncOperation {
  id              String    @id @default(uuid())
  opId            String    @unique
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId        String
  device          POSDevice @relation(fields: [deviceId], references: [deviceId])
  opType          String
  payload         Json
  clientTimestamp DateTime
  status          String    @default("pending")
  serverVersion   Int?
  serverAppliedAt DateTime?
  failureReason   String?
  /// Mensaje concreto (misma semántica que `failed[].details` en la respuesta de `sync/push`).
  failureDetails  String?   @db.Text

  @@index([storeId, clientTimestamp])
}

model OutboxEvent {
  id            String       @id @default(uuid())

  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json

  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now())

  lockedAt      DateTime?
  lockedBy      String?

  lastError     String?
  createdAt     DateTime     @default(now())
  processedAt   DateTime?

  @@index([status, availableAt])
  @@index([createdAt])
  @@index([aggregateType, aggregateId, createdAt])
  @@index([eventType, createdAt])
}

/// Append-only log for `GET /sync/pull` (server-originated ops). `serverVersion` is global monotonic.
/// `storeScopeId` null = visible to every store (shared catalog); set when an event is store-specific later.
model ServerChangeLog {
  serverVersion Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  opType        String
  payload       Json
  storeScopeId  String?

  @@index([storeScopeId])
}

